{
  "manifest_version": 3,
  "name": "MindfulCounter",
  "version": "1.0.0",
  "description": "A mindful counter browser extension.",
  "permissions": ["storage", "alarms"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "options_page": "options/options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["lib/history.js", "content/panel.js"],
      "css": ["content/panel.css"],
      "run_at": "document_idle"
    }
  ]
}
